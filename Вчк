<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>ВЧК • Абсолютный Контроль</title>
    <style>
        /* ===== ВСЕ СТИЛИ (сокращены, но полные в финальном файле) ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
        }
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 12px;
            transition: background 0.4s, color 0.4s;
            overflow-x: hidden;
            background: #050a14;
            color: #e8f0ff;
        }
        body.light {
            background: #f0f4fc;
            color: #1a2a3a;
        }
        .holo-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }
        .holo-bg span {
            position: absolute;
            border-radius: 50%;
            background: rgba(60, 150, 255, 0.05);
            box-shadow: 0 0 80px rgba(60, 150, 255, 0.06);
            animation: floatHolo 30s infinite alternate ease-in-out;
        }
        .holo-bg span:nth-child(1) {
            width: 30px;
            height: 30px;
            left: 5%;
            top: 10%;
            animation-duration: 32s;
        }
        .holo-bg span:nth-child(2) {
            width: 60px;
            height: 60px;
            left: 92%;
            top: 70%;
            animation-duration: 38s;
        }
        .holo-bg span:nth-child(3) {
            width: 18px;
            height: 18px;
            left: 45%;
            top: 88%;
            animation-duration: 26s;
        }
        .holo-bg span:nth-child(4) {
            width: 40px;
            height: 40px;
            left: 78%;
            top: 8%;
            animation-duration: 42s;
        }
        .holo-bg span:nth-child(5) {
            width: 22px;
            height: 22px;
            left: 15%;
            top: 55%;
            animation-duration: 28s;
        }
        .holo-bg span:nth-child(6) {
            width: 70px;
            height: 70px;
            left: 8%;
            top: 82%;
            animation-duration: 45s;
            opacity: 0.03;
        }
        @keyframes floatHolo {
            0% {
                transform: translateY(0) scale(1) rotate(0deg);
                opacity: 0.15;
            }
            100% {
                transform: translateY(-200px) scale(2.8) rotate(280deg);
                opacity: 0.8;
            }
        }
        .container {
            position: relative;
            z-index: 10;
            max-width: 1480px;
            width: 100%;
            border-radius: 32px;
            padding: 16px 18px;
            transition: background 0.4s, border 0.4s, box-shadow 0.4s;
            animation: fadeIn 0.6s ease;
            background: rgba(8, 14, 28, 0.78);
            backdrop-filter: blur(26px);
            border: 1px solid rgba(80, 160, 255, 0.08);
            box-shadow: 0 50px 100px rgba(0, 0, 0, 0.9);
        }
        body.light .container {
            background: rgba(255, 255, 255, 0.7);
            border: 1px solid rgba(80, 160, 255, 0.15);
            box-shadow: 0 20px 60px rgba(0, 20, 60, 0.08);
        }
        @keyframes fadeIn {
            0% {
                opacity: 0;
                transform: scale(0.96) translateY(20px);
            }
            100% {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }
        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 10px;
            padding-bottom: 14px;
            border-bottom: 1px solid rgba(80, 160, 255, 0.08);
            margin-bottom: 16px;
        }
        .top-bar .left {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
            cursor: pointer;
        }
        .top-bar .logo h1 {
            font-size: 1.8rem;
            font-weight: 800;
            letter-spacing: 3px;
            background: linear-gradient(135deg, #c8e0ff, #4a94e8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            pointer-events: none;
        }
        body.light .top-bar .logo h1 {
            background: linear-gradient(135deg, #1a4a8a, #4a94e8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .top-bar .logo .sub {
            font-size: 0.65rem;
            font-weight: 600;
            letter-spacing: 2px;
            color: #7a9ec8;
            text-transform: uppercase;
            pointer-events: none;
        }
        body.light .top-bar .logo .sub {
            color: #3a5a7a;
        }
        .top-bar .actions {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            align-items: center;
        }
        .top-bar .actions .desktop-only {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }
        .top-bar .actions .mobile-menu-btn {
            display: none;
            background: none;
            border: none;
            color: inherit;
            font-size: 1.8rem;
            cursor: pointer;
            padding: 4px 8px;
        }
        .top-bar .actions .mobile-dropdown {
            display: none;
            flex-direction: column;
            gap: 6px;
            width: 100%;
            padding: 12px 0;
            border-top: 1px solid rgba(80, 160, 255, 0.06);
            margin-top: 8px;
        }
        .top-bar .actions .mobile-dropdown.open {
            display: flex;
        }
        .btn {
            padding: 6px 14px;
            border-radius: 60px;
            border: none;
            font-weight: 700;
            font-size: 0.7rem;
            letter-spacing: 0.5px;
            cursor: pointer;
            transition: 0.25s;
            backdrop-filter: blur(4px);
            display: inline-flex;
            align-items: center;
            gap: 4px;
            white-space: nowrap;
        }
        body.dark .btn {
            background: rgba(30, 60, 120, 0.2);
            color: #d0e4ff;
            border: 1px solid rgba(80, 160, 255, 0.06);
        }
        body.light .btn {
            background: rgba(30, 80, 200, 0.06);
            color: #1a3a5a;
            border: 1px solid rgba(80, 160, 255, 0.1);
        }
        .btn:hover {
            transform: scale(1.03);
        }
        body.dark .btn:hover {
            background: rgba(50, 120, 230, 0.2);
        }
        body.light .btn:hover {
            background: rgba(30, 80, 200, 0.12);
        }
        .btn-primary {
            background: rgba(30, 80, 200, 0.25) !important;
            border-color: rgba(60, 140, 255, 0.15) !important;
        }
        .btn-primary:hover {
            background: rgba(50, 120, 230, 0.35) !important;
        }
        .btn-success {
            background: rgba(30, 130, 80, 0.2) !important;
            border-color: rgba(60, 200, 130, 0.1) !important;
        }
        .btn-success:hover {
            background: rgba(40, 180, 110, 0.3) !important;
        }
        .btn-danger {
            background: rgba(160, 40, 60, 0.15) !important;
            border-color: rgba(255, 80, 100, 0.08) !important;
        }
        .btn-danger:hover {
            background: rgba(200, 50, 70, 0.25) !important;
        }
        .btn-warning {
            background: rgba(200, 160, 30, 0.15) !important;
            border-color: rgba(255, 200, 50, 0.1) !important;
            color: #ffd866 !important;
        }
        .btn-warning:hover {
            background: rgba(200, 160, 30, 0.25) !important;
        }
        .admin-only {
            display: none !important;
        }
        .admin-only.visible {
            display: inline-flex !important;
        }
        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
            gap: 10px;
            margin-bottom: 16px;
        }
        .stat-item {
            padding: 10px 12px;
            border-radius: 20px;
            text-align: center;
            font-weight: 700;
            transition: background 0.3s;
        }
        body.dark .stat-item {
            background: rgba(0, 8, 24, 0.3);
            border: 1px solid rgba(80, 160, 255, 0.04);
        }
        body.light .stat-item {
            background: rgba(255, 255, 255, 0.4);
            border: 1px solid rgba(80, 160, 255, 0.06);
        }
        .stat-item .number {
            font-size: 1.4rem;
            color: #4a8cdb;
        }
        body.light .stat-item .number {
            color: #1a5a9a;
        }
        .stat-item .label {
            font-size: 0.55rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            opacity: 0.7;
        }
        .public-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }
        @media (min-width: 768px) {
            .public-grid {
                grid-template-columns: 1fr 1.2fr;
                gap: 32px;
            }
        }
        .info-card {
            padding: 18px 20px;
            border-radius: 24px;
            transition: background 0.3s, border 0.3s;
        }
        body.dark .info-card {
            background: rgba(0, 8, 24, 0.35);
            border: 1px solid rgba(80, 160, 255, 0.04);
        }
        body.light .info-card {
            background: rgba(255, 255, 255, 0.3);
            border: 1px solid rgba(80, 160, 255, 0.06);
        }
        .info-card .title {
            font-weight: 700;
            font-size: 1.2rem;
            letter-spacing: 1px;
            color: #b0d0ff;
            border-left: 4px solid #4a8cdb;
            padding-left: 14px;
            margin-bottom: 16px;
        }
        body.light .info-card .title {
            color: #1a4a7a;
        }
        .info-card .text-block {
            font-size: 0.95rem;
            line-height: 1.6;
            margin-bottom: 12px;
        }
        .contact-line {
            display: flex;
            gap: 10px;
            padding: 6px 0;
            border-bottom: 1px solid rgba(80, 160, 255, 0.04);
            font-size: 0.85rem;
            flex-wrap: wrap;
        }
        .contact-line .label {
            font-weight: 700;
            width: 80px;
            text-transform: uppercase;
            font-size: 0.6rem;
            letter-spacing: 1px;
            opacity: 0.7;
        }
        .contact-line .value {
            font-weight: 600;
            word-break: break-word;
        }
        .mission-block {
            margin-top: 12px;
            padding: 14px 16px;
            border-radius: 16px;
            border-left: 4px solid rgba(60, 140, 255, 0.25);
            font-size: 0.95rem;
            font-weight: 600;
            font-style: italic;
        }
        body.dark .mission-block {
            background: rgba(30, 80, 200, 0.04);
            color: #b0d0ff;
        }
        body.light .mission-block {
            background: rgba(30, 80, 200, 0.04);
            color: #1a4a7a;
        }
        .status-indicator {
            margin-top: 12px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
            font-size: 0.8rem;
            opacity: 0.8;
        }
        .status-dot {
            width: 10px;
            height: 10px;
            background: #4a8cdb;
            border-radius: 50%;
            box-shadow: 0 0 30px #4a8cdb77;
            animation: pulse 2s infinite;
        }
        @keyframes pulse {
            0% {
                opacity: 0.4;
                transform: scale(0.9);
            }
            50% {
                opacity: 1;
                transform: scale(1.2);
            }
            100% {
                opacity: 0.4;
                transform: scale(0.9);
            }
        }
        .edit-mode .editable {
            outline: 2px dashed rgba(80, 180, 255, 0.25);
            outline-offset: 4px;
            border-radius: 6px;
            padding: 2px 6px;
            cursor: text;
            transition: 0.2s;
        }
        .edit-mode .editable:hover {
            outline: 2px dashed rgba(80, 180, 255, 0.5);
        }
        .edit-mode .editable:focus {
            outline: 2px solid rgba(80, 180, 255, 0.7);
            background: rgba(0, 20, 60, 0.2);
            border-radius: 8px;
        }
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(12px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            padding: 16px;
        }
        .modal-overlay.show {
            display: flex;
        }
        .modal {
            background: rgba(12, 20, 36, 0.95);
            border: 1px solid rgba(80, 160, 255, 0.12);
            border-radius: 32px;
            padding: 24px 20px;
            max-width: 480px;
            width: 100%;
            backdrop-filter: blur(20px);
            box-shadow: 0 40px 80px rgba(0, 0, 0, 0.8);
            max-height: 90vh;
            overflow-y: auto;
        }
        body.light .modal {
            background: rgba(255, 255, 255, 0.95);
            border: 1px solid rgba(80, 160, 255, 0.15);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
        }
        .modal h3 {
            font-size: 1.2rem;
            font-weight: 700;
            margin-bottom: 4px;
        }
        body.dark .modal h3 {
            color: #b0d0ff;
        }
        body.light .modal h3 {
            color: #1a4a7a;
        }
        .modal p {
            opacity: 0.7;
            margin-bottom: 16px;
            font-size: 0.85rem;
        }
        .modal input,
        .modal select {
            width: 100%;
            padding: 10px 16px;
            border-radius: 60px;
            border: 1px solid rgba(80, 160, 255, 0.12);
            background: rgba(0, 8, 20, 0.3);
            color: inherit;
            font-size: 0.95rem;
            text-align: center;
            outline: none;
            backdrop-filter: blur(4px);
            margin-bottom: 8px;
        }
        .modal input:focus,
        .modal select:focus {
            border-color: #4a8cdb;
        }
        .modal .modal-actions {
            display: flex;
            gap: 10px;
            margin-top: 16px;
        }
        .modal .modal-actions button {
            flex: 1;
            padding: 10px 14px;
            border-radius: 60px;
            border: none;
            font-weight: 700;
            font-size: 0.85rem;
            cursor: pointer;
            transition: 0.3s;
        }
        .modal .modal-actions .btn-confirm {
            background: rgba(30, 80, 200, 0.3);
            border: 1px solid rgba(80, 160, 255, 0.1);
            color: inherit;
        }
        .modal .modal-actions .btn-confirm:hover {
            background: rgba(50, 120, 230, 0.4);
        }
        .modal .modal-actions .btn-cancel {
            background: rgba(80, 80, 100, 0.1);
            border: 1px solid rgba(80, 80, 100, 0.05);
            color: inherit;
            opacity: 0.6;
        }
        .modal .modal-actions .btn-cancel:hover {
            background: rgba(80, 80, 100, 0.2);
        }
        .modal-error {
            color: #ff7a7a;
            font-size: 0.8rem;
            font-weight: 600;
            margin-top: 8px;
            text-align: center;
        }
        .blocks-section {
            margin: 20px 0;
        }
        .blocks-section .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            flex-wrap: wrap;
            gap: 10px;
        }
        .blocks-section .section-header h2 {
            font-size: 1.4rem;
            font-weight: 700;
            letter-spacing: 2px;
            border-left: 4px solid #4a8cdb;
            padding-left: 14px;
        }
        body.dark .blocks-section .section-header h2 {
            color: #b0d0ff;
        }
        body.light .blocks-section .section-header h2 {
            color: #1a4a7a;
        }
        .blocks-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 16px;
        }
        @media (min-width: 600px) {
            .blocks-grid {
                grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            }
        }
        .block-item {
            padding: 16px 18px;
            border-radius: 24px;
            transition: background 0.3s, border 0.3s;
            position: relative;
        }
        body.dark .block-item {
            background: rgba(0, 8, 24, 0.3);
            border: 1px solid rgba(80, 160, 255, 0.06);
        }
        body.light .block-item {
            background: rgba(255, 255, 255, 0.25);
            border: 1px solid rgba(80, 160, 255, 0.06);
        }
        .block-item:hover {
            border-color: rgba(80, 160, 255, 0.15);
        }
        .block-item .block-image {
            width: 100%;
            height: 160px;
            object-fit: cover;
            border-radius: 14px;
            margin-bottom: 12px;
            background: rgba(80, 160, 255, 0.05);
        }
        .block-item .block-title {
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: 6px;
        }
        body.dark .block-item .block-title {
            color: #d0e8ff;
        }
        body.light .block-item .block-title {
            color: #1a3a5a;
        }
        .block-item .block-text {
            font-size: 0.85rem;
            line-height: 1.6;
            opacity: 0.8;
        }
        .block-item .block-actions {
            position: absolute;
            top: 10px;
            right: 10px;
            display: flex;
            gap: 4px;
        }
        .block-item .block-actions .btn {
            font-size: 0.6rem;
            padding: 4px 8px;
        }
        .modal-block .modal .field {
            margin-bottom: 12px;
        }
        .modal-block .modal .field label {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 700;
            opacity: 0.6;
            display: block;
            margin-bottom: 4px;
        }
        .modal-block .modal .field input,
        .modal-block .modal .field textarea {
            width: 100%;
            padding: 8px 14px;
            border-radius: 14px;
            border: 1px solid rgba(80, 160, 255, 0.06);
            background: rgba(0, 8, 20, 0.15);
            color: inherit;
            font-size: 0.9rem;
            outline: none;
            transition: 0.2s;
        }
        .modal-block .modal .field input:focus,
        .modal-block .modal .field textarea:focus {
            border-color: #4a8cdb;
        }
        .modal-block .modal .field textarea {
            resize: vertical;
            min-height: 60px;
        }
        .modal-block .modal .field .photo-preview {
            max-width: 100%;
            max-height: 160px;
            border-radius: 14px;
            margin-top: 6px;
            object-fit: cover;
            background: rgba(80, 160, 255, 0.05);
        }
        .db-panel {
            display: grid;
            grid-template-columns: 1fr;
            gap: 16px;
        }
        @media (min-width: 768px) {
            .db-panel {
                grid-template-columns: 1fr 1.2fr;
                gap: 24px;
            }
        }
        .db-card {
            padding: 16px 18px;
            border-radius: 24px;
            transition: background 0.3s, border 0.3s;
        }
        body.dark .db-card {
            background: rgba(0, 8, 24, 0.35);
            border: 1px solid rgba(80, 160, 255, 0.04);
        }
        body.light .db-card {
            background: rgba(255, 255, 255, 0.3);
            border: 1px solid rgba(80, 160, 255, 0.06);
        }
        .db-card h3 {
            font-weight: 700;
            font-size: 1rem;
