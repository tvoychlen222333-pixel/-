        }
        .photo-upload img:hover {
            border-color: #4a8cdb;
        }
        .btn-group {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            margin-top: 10px;
        }
        .btn-group .btn {
            font-size: 0.7rem;
            padding: 4px 12px;
        }
        .db-table-wrap {
            overflow-x: auto;
            margin-top: 10px;
            border-radius: 16px;
            padding: 4px;
            transition: background 0.3s;
        }
