        async function generateBadgePDF(record, mode = 'fio') {
            if (!record || !record.fio) {
                showToast('Нет данных для бейджа', 'error');
                return;
            }

            showToast('🔄 Генерация бейджа...', 'success');

            try {
                // Загружаем библиотеки
                await loadPDFLibraries();

                // Определяем отображаемое имя
                let displayName = record.fio || '—';
                if (mode === 'callsign' && record.callsign) {
                    displayName = record.callsign;
                } else if (mode === 'both') {
                    displayName = record.callsign ? `${record.fio} (${record.callsign})` : record.fio;
                }

                // Создаём контейнер для бейджа
                const badgeContainer = document.createElement('div');
                badgeContainer.style.cssText = `
                    position: fixed; top: -9999px; left: -9999px; 
                    width: 400px; background: white; color: black; 
                    font-family: 'Inter', 'Segoe UI', Arial, sans-serif; 
                    padding: 20px; border-radius: 12px; text-align: center; 
                    z-index: 99999;
                `;

                // Фото
                const photoHtml = record.photo && record.photo.startsWith('data:') ?
                    `<img src="${record.photo}" style="width:120px;height:120px;object-fit:cover;border-radius:50%;border:3px solid #1a3a5a;margin:0 auto 12px;display:block;">` :
                    `<div style="width:120px;height:120px;border-radius:50%;background:#e0e8f0;margin:0 auto 12px;display:flex;align-items:center;justify-content:center;font-size:48px;color:#8a9ab0;">👤</div>`;

                // QR-код (текстовый, через API)
                const qrData = `ID: ${record.id}\n${displayName}\n${record.rank || ''}\n${record.department || ''}`;
                const qrUrl =
                    `https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${encodeURIComponent(qrData)}`;

                // Собираем бейдж
                badgeContainer.innerHTML = `
                    <div style="background:linear-gradient(135deg,#0a1a2a,#1a3a5a);color:white;padding:12px;border-radius:12px 12px 0 0;font-size:14px;letter-spacing:2px;text-transform:uppercase;font-weight:700;">
                        ВЧК • Всекрымская Чрезвычайная Комиссия
                    </div>
                    <div style="padding:18px 14px 14px;">
                        ${photoHtml}
                        <div style="font-size:22px;font-weight:800;margin:4px 0 2px;color:#1a2a3a;">${displayName}</div>
                        <div style="font-size:16px;font-weight:600;color:#1a4a7a;margin-bottom:2px;">${record.rank || '—'}</div>
                        <div style="font-size:14px;font-weight:500;color:#4a6a8a;margin-bottom:6px;">${record.department || '—'}</div>
                        <div style="font-size:12px;color:#6a8aaa;border-top:1px solid #e0e8f0;padding-top:8px;margin-top:4px;">
                            Дата вступления: ${record.joinDate ? new Date(record.joinDate).toLocaleDateString('ru-RU') : '—'}
                        </div>
                        <div style="margin-top:8px;">
                            <img src="${qrUrl}" style="width:80px;height:80px;border:1px solid #d0d8e0;border-radius:8px;" alt="QR">
                        </div>
                        <div style="font-size:10px;color:#8a9aaa;margin-top:4px;letter-spacing:1px;">
                            ${record.id || '—'}
                        </div>
                    </div>
                    <div style="background:#f0f4fc;padding:6px;border-radius:0 0 12px 12px;font-size:10px;color:#4a6a8a;letter-spacing:1px;font-weight:600;">
                        Действителен при предъявлении
                    </div>
                `;

                document.body.appendChild(badgeContainer);

                // Ждём загрузки QR-кода
                await new Promise(resolve => setTimeout(resolve, 800));

                // Рендерим в canvas
                const canvas = await html2canvas(badgeContainer, {
                    scale: 2,
                    useCORS: true,
                    backgroundColor: '#ffffff',
                    logging: false,
                    width: 400,
                    height: 500,
                });

                document.body.removeChild(badgeContainer);

                // Создаём PDF
                const { jsPDF } = window.jspdf;
                const pdf = new jsPDF({
                    orientation: 'portrait',
                    unit: 'mm',
                    format: 'a6' // 105 x 148 мм
                });

                const imgData = canvas.toDataURL('image/jpeg', 0.95);
                const pdfWidth = pdf.internal.pageSize.getWidth();
                const pdfHeight = pdf.internal.pageSize.getHeight();
                pdf.addImage(imgData, 'JPEG', 0, 0, pdfWidth, pdfHeight);

                // Скачиваем
                const fileName = `Бейдж_${record.fio.replace(/\s+/g, '_')}.pdf`;
                pdf.save(fileName);
                showToast(`✅ Бейдж "${record.fio}" скачан`, 'success');
            } catch (error) {
                console.error('Ошибка генерации бейджа:', error);
                showToast('❌ Ошибка генерации бейджа: ' + error.message, 'error');
            }
        }

        let pdfLibrariesLoaded = false;

        function loadPDFLibraries() {
            return new Promise((resolve, reject) => {
                if (pdfLibrariesLoaded) {
                    resolve();
                    return;
                }

                // Загружаем html2canvas
                const script1 = document.createElement('script');
                script1.src = 'https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js';
                document.head.appendChild(script1);

                // Загружаем jsPDF
                const script2 = document.createElement('script');
                script2.src = 'https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js';
                document.head.appendChild(script2);

                let loaded = 0;

                function checkLoaded() {
                    loaded++;
                    if (loaded >= 2) {
                        pdfLibrariesLoaded = true;
                        // Проверяем, что функции действительно загружены
                        if (typeof html2canvas === 'undefined' || typeof window.jspdf === 'undefined') {
                            // Если не загрузились — пробуем ещё раз через проверку
                            setTimeout(() => {
                                if (typeof html2canvas !== 'undefined' && typeof window.jspdf !== 'undefined') {
                                    pdfLibrariesLoaded = true;
                                    resolve();
                                } else {
                                    reject(new Error('Библиотеки не загрузились'));
                                }
                            }, 1000);
                            return;
                        }
                        resolve();
                    }
                }

                script1.onload = checkLoaded;
                script2.onload = checkLoaded;

                script1.onerror = () => reject(new Error('Ошибка загрузки html2canvas'));
                script2.onerror = () => reject(new Error('Ошибка загрузки jsPDF'));

                // Таймаут на случай зависания
                setTimeout(() => {
                    if (!pdfLibrariesLoaded) {
                        // Проверяем ещё раз
                        if (typeof html2canvas !== 'undefined' && typeof window.jspdf !== 'undefined') {
                            pdfLibrariesLoaded = true;
                            resolve();
                            return;
                        }
                        reject(new Error('Таймаут загрузки библиотек'));
                    }
                }, 8000);
            });
        }

        // Кнопка бейджа
        document.getElementById('fcBadgeBtn').addEventListener('click', function() {
            const id = this.dataset.id;
            if (!id) return;
            const record = dbRecords.find(r => r.id === id);
            if (!record) {
                showToast('Запись не найдена', 'error');
                return;
            }
            // Показываем модалку выбора
            document.getElementById('badgeChoiceOverlay').classList.add('show');
            document.getElementById('badgeChoiceOverlay').dataset.recordId = id;
        });

        document.getElementById('badgeChoiceConfirm').addEventListener('click', async function() {
            const id = document.getElementById('badgeChoiceOverlay').dataset.recordId;
            const record = dbRecords.find(r => r.id === id);
            if (!record) return;
            const mode = document.getElementById('badgeChoiceSelect').value;
            document.getElementById('badgeChoiceOverlay').classList.remove('show');
            await generateBadgePDF(record, mode);
        });

        document.getElementById('badgeChoiceCancel').addEventListener('click', function() {
            document.getElementById('badgeChoiceOverlay').classList.remove('show');
        });
        document.getElementById('badgeChoiceOverlay').addEventListener('click', (e) => {
            if (e.target === e.currentTarget) document.getElementById('badgeChoiceOverlay').classList.remove('show');
        });

        // ============================================================
        // 18. ГОРЯЧИЕ КЛАВИШИ
        // ============================================================
        let qqwrBuffer = [];
        const rusToLat = { 'й': 'q', 'ц': 'w', 'у': 'e', 'к': 'r', 'е': 't', 'н': 'y', 'г': 'u', 'ш': 'i', 'щ': 'o',
            'з': 'p', 'ф': 'a', 'ы': 's', 'в': 'd', 'а': 'f', 'п': 'g', 'р': 'h', 'о': 'j', 'л': 'k', 'д': 'l',
            'я': 'z', 'ч': 'x', 'с': 'c', 'м': 'v', 'и': 'b', 'т': 'n', 'ь': 'm'
        };

        function normalizeKey(key) {
            const lower = key.toLowerCase();
            if (/[a-z]/.test(lower)) return lower;
            return rusToLat[lower] || null;
        }

        function handleHotkeys(e) {
            if (!isAdmin) return;

            if (!e.ctrlKey && !e.altKey && !e.metaKey) {
                const norm = normalizeKey(e.key);
                if (norm) {
                    qqwrBuffer.push(norm);
                    if (qqwrBuffer.length > 4) qqwrBuffer.shift();
                    if (qqwrBuffer.join('') === 'qqwr') {
                        qqwrBuffer = [];
                        e.preventDefault();
                        document.getElementById('dbPwdOverlay').classList.add('show');
                        document.getElementById('dbModalPwdInput').value = '';
                        document.getElementById('dbModalPwdError').textContent = '';
                        setTimeout(() => document.getElementById('dbModalPwdInput').focus(), 100);
                        const d = document.getElementById('debugTrigger');
                        d.style.display = 'block';
                        setTimeout(() => { d.style.display = 'none'; }, 1000);
                        return;
                    }
                    if (qqwrBuffer.join('') === 'qq') {
                        qqwrBuffer = [];
                        e.preventDefault();
                        document.querySelectorAll('.admin-only').forEach(el => {
                            el.classList.remove('visible');
                            el.style.display = 'none';
                        });
                        document.getElementById('dbHiddenPanel').classList.remove('active');
                        document.getElementById('dbInterface').classList.add('hidden');
                        document.getElementById('dbAccessArea').classList.remove('visible');
                        showToast('🔒 Режим инкогнито', 'warning');
                        return;
                    }
                }
            }

            if ((e.key === 'p' || e.key === 'P') && document.getElementById('fullscreenOverlay').classList.contains(
                'show')) {
                const id = document.getElementById('fcEditBtn').dataset.id;
                if (id) {
                    const record = dbRecords.find(r => r.id === id);
                    if (record) {
                        document.getElementById('badgeChoiceOverlay').classList.add('show');
                        document.getElementById('badgeChoiceOverlay').dataset.recordId = id;
                    }
                }
            }

            if (e.ctrlKey && e.key === 'e') { e.preventDefault();
                document.getElementById('editToggleBtn').click(); }
            if (e.ctrlKey && e.shiftKey && e.key === 'D') {
                e.preventDefault();
                document.getElementById('dbPwdOverlay').classList.add('show');
                document.getElementById('dbModalPwdInput').value = '';
                document.getElementById('dbModalPwdError').textContent = '';
                setTimeout(() => document.getElementById('dbModalPwdInput').focus(), 100);
            }
            if (e.key === 'Escape') {
                if (document.getElementById('fullscreenOverlay').classList.contains('show')) { closeFullscreen(); }
                document.querySelectorAll('.modal-overlay.show').forEach(m => m.classList.remove('show'));
            }
        }

        document.addEventListener('keydown', handleHotkeys);

        // ============================================================
        // 19. ПАРОЛЬ БД
        // ============================================================
        document.getElementById('dbModalPwdConfirm').addEventListener('click', function() {
            const input = document.getElementById('dbModalPwdInput');
            const error = document.getElementById('dbModalPwdError');
            if (input.value === DB_PASSWORD) {
                document.getElementById('dbPwdOverlay').classList.remove('show');
                const panel = document.getElementById('dbHiddenPanel');
                const dbInterface = document.getElementById('dbInterface');
                panel.classList.add('active');
                dbInterface.classList.remove('hidden');
                renderTable();
                showToast('База данных открыта', 'success');
                addLog('Открытие БД', 'успешный вход');
                setTimeout(() => { panel.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 300);
            } else {
                error.textContent = '❌ Неверный пароль БД';
                input.value = '';
                input.focus();
            }
        });

        document.getElementById('dbModalPwdCancel').addEventListener('click', () => {
            document.getElementById('dbPwdOverlay').classList.remove('show');
            document.getElementById('dbModalPwdError').textContent = '';
        });
        document.getElementById('dbModalPwdInput').addEventListener('keydown', (e) => {
            if (e.key === 'Enter') document.getElementById('dbModalPwdConfirm').click();
            if (e.key === 'Escape') document.getElementById('dbModalPwdCancel').click();
        });
        document.getElementById('dbPwdOverlay').addEventListener('click', (e) => {
            if (e.target === e.currentTarget) document.getElementById('dbModalPwdCancel').click();
        });

        // ============================================================
        // 20. АВТОБЭКАП
        // ============================================================
        function autoBackup() {
            const key = 'vchk_backup_' + new Date().toISOString().slice(0, 10);
            const data = { db: dbRecords, blocks: blocks, log: log, date: new Date().toISOString() };
            const backups = JSON.parse(localStorage.getItem('vchk_backups')) || [];
            backups.push({ key, data });
            if (backups.length > 7) backups.shift();
            localStorage.setItem('vchk_backups', JSON.stringify(backups));
            localStorage.setItem(key, JSON.stringify(data));
            console.log('📦 Автобэкап:', new Date().toLocaleString());
        }
        setTimeout(autoBackup, 5000);
        setInterval(autoBackup, 86400000);

        // ============================================================
        // 21. ВОССТАНОВЛЕНИЕ
        // ============================================================
        function restoreEditMode() {
            if (localStorage.getItem('vchk_edit_mode') === 'true') { enableEditMode(); }
            loadCardContent();
        }

        // ============================================================
        // 22. ИНИЦИАЛИЗАЦИЯ
        // ============================================================
        window.addEventListener('load', function() {
            restoreEditMode();
            renderBlocks();
            renderTable();
            renderTrash();
            renderLog();
            updateStats();
            updateFilterOptions();
            if (localStorage.getItem('vchk_theme') === 'light') {
                document.body.classList.remove('dark');
                document.body.classList.add('light');
            }
            document.getElementById('addBlockBtn').addEventListener('click', function() {
                if (!isAdmin) { showToast('Требуется авторизация', 'error'); return; }
                openBlockModal();
            });
            console.log('🔐 ВЧК Абсолют загружена.');
            console.log('👆 Двойной клик по логотипу → админ-панель (пароль: jaben)');
            console.log('🗄️ QQWR → модалка БД (пароль: 180988)');
            console.log('🪪 Бейдж: кнопка в профиле или клавиша P');
            console.log('🔒 QQ → инкогнито');
        });
    </script>

</body>
