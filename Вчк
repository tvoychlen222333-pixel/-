                            <button class="btn" id="exportCsvBtn">📊 CSV</button>
                            <button class="btn" id="exportJsonBtn">📤 JSON</button>
                            <button class="btn" id="importJsonBtn">📥 JSON</button>
                            <input type="file" id="importFileInput" accept=".json" style="display:none;">
                            <button class="btn" id="showLogBtn">📋 Лог</button>
                        </div>
                    </div>
                </div>
                <div id="logPanel" style="display:none; margin-top:12px; padding:10px; border-radius:20px; transition:background 0.3s; max-height:160px; overflow-y:auto;">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;"><h4 style="font-weight:700; font-size:0.85rem;">📋 История</h4><button class="btn admin-only" id="clearLogBtn" style="padding:2px 12px; font-size:0.6rem;">Очистить</button></div>
                    <div id="logContent" style="font-size:0.75rem; line-height:1.5;"></div>
                </div>
            </div>
        </div>

        <div id="trashPanel" class="admin-only">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;"><h4 style="font-weight:700; font-size:0.85rem;">🗑️ Корзина</h4><button class="btn btn-danger admin-only" id="clearTrashBtn" style="padding:2px 12px; font-size:0.6rem;">Очистить</button></div>
            <div id="trashContent"></div>
        </div>

        <div class="ghost-hint">ВЧК • Абсолют</div>
    </div>

    <script>
        // ============================================================
        // 1. ПАРОЛИ
        // ============================================================
        const EDITOR_PASSWORD = 'jaben';
        const DB_PASSWORD = '180988';
        const OBSERVER_PASSWORD = 'observer';
        const ADMIN_PASSWORD = 'jaben';

        // ============================================================
        // 2. СОСТОЯНИЕ
        // ============================================================
        let isAdmin = false;
        let observerMode = false;
        let editModeActive = false;
        let currentEditId = null;
        let dbRecords = JSON.parse(localStorage.getItem('vchk_db')) || [];
        let blocks = JSON.parse(localStorage.getItem('vchk_blocks')) || [];
        let log = JSON.parse(localStorage.getItem('vchk_log')) || [];
        let currentFiles = [];
        let currentSort = { field: 'fio', asc: true };
        let formChanged = false;

        // ============================================================
        // 3. TOAST
        // ============================================================
        function showToast(msg, type = 'success') {
            const c = document.getElementById('toastContainer');
            const t = document.createElement('div');
            t.className = `toast ${type}`;
            t.textContent = msg;
            c.appendChild(t);
            setTimeout(() => { t.style.opacity = '0';
                setTimeout(() => t.remove(), 300); }, 3000);
        }

        // ============================================================
        // 4. ЛОГ
        // ============================================================
        function addLog(action, detail = '') {
            if (!isAdmin) return;
            log.unshift({ time: new Date().toLocaleString(), action, detail });
            if (log.length > 100) log.pop();
            localStorage.setItem('vchk_log', JSON.stringify(log));
            renderLog();
        }

        function renderLog() {
            document.getElementById('logContent').innerHTML = log.map(e =>
                `<div style="opacity:0.7; padding:2px 0; border-bottom:1px solid rgba(80,160,255,0.04);"><strong>${e.time}</strong> — ${e.action} ${e.detail ? '— ' + e.detail : ''}</div>`
            ).join('');
        }

        // ============================================================
        // 5. БЛОКИ
        // ============================================================
        function renderBlocks() {
            const grid = document.getElementById('blocksGrid');
            grid.innerHTML = '';
            if (blocks.length === 0) {
                grid.innerHTML =
                    `<div style="grid-column:1/-1; text-align:center; opacity:0.4; padding:30px;">Нет блоков</div>`;
                return;
            }
            blocks.forEach(b => {
                const div = document.createElement('div');
                div.className = 'block-item';
                div.innerHTML = `
                    ${b.image ? `<img class="block-image" src="${b.image}" alt="${b.title}">` : ''}
                    <div class="block-title">${b.title || 'Без заголовка'}</div>
                    <div class="block-text">${b.content || ''}</div>
                    ${isAdmin ? `<div class="block-actions"><button class="btn btn-primary" data-action="edit" data-id="${b.id}">✎</button><button class="btn btn-danger" data-action="delete" data-id="${b.id}">✕</button></div>` : ''}
                `;
                grid.appendChild(div);
                if (isAdmin) {
                    div.querySelector('[data-action="edit"]')?.addEventListener('click', e => { e.stopPropagation();
                        openBlockModal(b.id); });
                    div.querySelector('[data-action="delete"]')?.addEventListener('click', e => { e.stopPropagation(); if (
                            confirm(`Удалить блок "${b.title || 'без заголовка'}"?`)) { blocks = blocks.filter(x => x
                                .id !== b.id);
                            saveBlocks();
                            renderBlocks();
                            showToast('Блок удалён', 'warning'); } });
                }
            });
        }

        function saveBlocks() { localStorage.setItem('vchk_blocks', JSON.stringify(blocks)); }

        function openBlockModal(id = null) {
            const modal = document.getElementById('blockModal');
            document.getElementById('blockModalTitle').textContent = id ? '✎ Редактировать блок' : '➕ Добавить блок';
            const block = id ? blocks.find(b => b.id === id) : null;
            document.getElementById('blockTitle').value = block?.title || '';
            document.getElementById('blockContent').value = block?.content || '';
            const preview = document.getElementById('blockImagePreview');
            if (block?.image) { preview.src = block.image;
                preview.style.display = 'block'; } else { preview.style.display = 'none';
                preview.src = ''; }
            document.getElementById('blockImageInput').value = '';
            document.getElementById('blockModalError').textContent = '';
            modal.dataset.editId = id || '';
            modal.classList.add('show');
        }

        function closeBlockModal() { document.getElementById('blockModal').classList.remove('show'); }

        document.getElementById('blockImageInput').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = (ev) => { const p = document.getElementById('blockImagePreview');
                p.src = ev.target.result;
                p.style.display = 'block'; };
            reader.readAsDataURL(file);
        });

        document.getElementById('blockModalConfirm').addEventListener('click', function() {
            const title = document.getElementById('blockTitle').value.trim();
            const content = document.getElementById('blockContent').value.trim();
            const preview = document.getElementById('blockImagePreview');
            const error = document.getElementById('blockModalError');
            if (!title && !content && !preview.src) { error.textContent = '❌ Заполните хотя бы одно поле'; return; }
            error.textContent = '';
            const image = preview.src && preview.style.display !== 'none' ? preview.src : '';
            const id = document.getElementById('blockModal').dataset.editId;
            if (id) {
                const b = blocks.find(x => x.id === id);
                if (b) { b.title = title;
                    b.content = content; if (image) b.image = image;
                    saveBlocks();
                    renderBlocks();
                    showToast('Блок обновлён', 'success'); }
            } else {
                blocks.push({ id: Date.now().toString(36) + Math.random().toString(36).slice(2, 6), title, content,
                    image });
                saveBlocks();
                renderBlocks();
                showToast('Блок добавлен', 'success');
            }
            closeBlockModal();
        });
        document.getElementById('blockModalCancel').addEventListener('click', closeBlockModal);
        document.getElementById('blockModal').addEventListener('click', e => { if (e.target === e.currentTarget)
                closeBlockModal(); });

        // ============================================================
        // 6. АДМИН-ВХОД
        // ============================================================
        let logoClickCount = 0,
            logoClickTimer = null;
        document.getElementById('logoTrigger').addEventListener('click', () => {
            logoClickCount++;
            if (logoClickCount === 1) { logoClickTimer = setTimeout(() => { logoClickCount = 0; }, 600); } else if (
                logoClickCount === 2) {
                clearTimeout(logoClickTimer);
                logoClickCount = 0;
                if (!isAdmin) {
                    document.getElementById('adminPwdOverlay').classList.add('show');
                    document.getElementById('adminPwdInput').value = '';
                    document.getElementById('adminPwdError').textContent = '';
                    setTimeout(() => document.getElementById('adminPwdInput').focus(), 100);
                } else { showToast('Вы уже авторизованы', 'warning'); }
            }
        });

        document.getElementById('adminPwdConfirm').addEventListener('click', function() {
            if (document.getElementById('adminPwdInput').value === ADMIN_PASSWORD) {
                document.getElementById('adminPwdOverlay').classList.remove('show');
                isAdmin = true;
                document.querySelectorAll('.admin-only').forEach(el => { el.classList.add('visible'); });
                renderBlocks();
                renderTable();
                renderTrash();
                showToast('Добро пожаловать, администратор!', 'success');
                addLog('Авторизация', 'успешный вход');
            } else {
                document.getElementById('adminPwdError').textContent = '❌ Неверный пароль';
                document.getElementById('adminPwdInput').value = '';
                document.getElementById('adminPwdInput').focus();
            }
        });
        document.getElementById('adminPwdCancel').addEventListener('click', () => { document.getElementById(
                'adminPwdOverlay').classList.remove('show');
            document.getElementById('adminPwdError').textContent = ''; });
        document.getElementById('adminPwdInput').addEventListener('keydown', (e) => { if (e.key === 'Enter') document
                .getElementById('adminPwdConfirm').click(); if (e.key === 'Escape') document.getElementById(
                    'adminPwdCancel').click(); });
        document.getElementById('adminPwdOverlay').addEventListener('click', (e) => { if (e.target === e.currentTarget)
                document.getElementById('adminPwdCancel').click(); });

        // ============================================================
        // 7. ТЕМА
        // ============================================================
        document.getElementById('themeToggle').addEventListener('click', () => {
            document.body.classList.toggle('dark');
            document.body.classList.toggle('light');
            localStorage.setItem('vchk_theme', document.body.classList.contains('dark') ? 'dark' : 'light');
        });
        if (localStorage.getItem('vchk_theme') === 'light') { document.body.classList.remove('dark');
            document.body.classList.add('light'); }

        // ============================================================
        // 8. МОБИЛЬНОЕ МЕНЮ
        // ============================================================
        document.getElementById('mobileMenuBtn').addEventListener('click', () => {
            document.getElementById('mobileDropdown').classList.toggle('open');
        });
        document.querySelectorAll('.mobile-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const targetId = this.dataset.target;
                const targetBtn = document.getElementById(targetId);
                if (targetBtn) { targetBtn.click();
                    document.getElementById('mobileDropdown').classList.remove('open'); }
            });
        });

        // ============================================================
        // 9. РЕДАКТОР КАРТОЧКИ
        // ============================================================
        const editableElements = document.querySelectorAll('.editable');
        const publicCard = document.getElementById('publicCard');

        function enableEditMode() {
            editModeActive = true;
            publicCard.classList.add('edit-mode');
            editableElements.forEach(el => el.contentEditable = 'true');
            document.getElementById('editToggleBtn').textContent = '💾 Сохранить';
            document.getElementById('editToggleBtn').classList.add('btn-primary');
            localStorage.setItem('vchk_edit_mode', 'true');
            editableElements.forEach(el => { el.addEventListener('input', saveCardContent); });
            showToast('Режим редактирования включён', 'success');
        }

        function disableEditMode() {
            editModeActive = false;
            publicCard.classList.remove('edit-mode');
            editableElements.forEach(el => { el.contentEditable = 'false';
                el.removeEventListener('input', saveCardContent); });
            document.getElementById('editToggleBtn').textContent = '✎ Редактировать';
            document.getElementById('editToggleBtn').classList.remove('btn-primary');
            localStorage.setItem('vchk_edit_mode', 'false');
            saveCardContent();
            showToast('Режим редактирования выключен', 'warning');
        }

        function saveCardContent() {
            const data = {};
            editableElements.forEach(el => { data[el.id] = el.innerHTML; });
            localStorage.setItem('vchk_card_data', JSON.stringify(data));
        }

        function loadCardContent() {
            const raw = localStorage.getItem('vchk_card_data');
            if (!raw) return;
            try {
                const data = JSON.parse(raw);
                editableElements.forEach(el => { if (data[el.id] !== undefined) el.innerHTML = data[el.id]; });
            } catch (e) {}
        }

        document.getElementById('editToggleBtn').addEventListener('click', function() {
            if (!isAdmin) { showToast('Требуется авторизация', 'error'); return; }
            if (editModeActive) { disableEditMode(); return; }
            document.getElementById('editPwdOverlay').classList.add('show');
            document.getElementById('editPwdInput').value = '';
            document.getElementById('editPwdError').textContent = '';
            setTimeout(() => document.getElementById('editPwdInput').focus(), 100);
        });

        document.getElementById('editPwdConfirm').addEventListener('click', function() {
            if (document.getElementById('editPwdInput').value === EDITOR_PASSWORD) {
                document.getElementById('editPwdOverlay').classList.remove('show');
                enableEditMode();
            } else {
                document.getElementById('editPwdError').textContent = '❌ Неверный пароль';
                document.getElementById('editPwdInput').value = '';
                document.getElementById('editPwdInput').focus();
            }
        });
        document.getElementById('editPwdCancel').addEventListener('click', () => { document.getElementById(
                'editPwdOverlay').classList.remove('show');
            document.getElementById('editPwdError').textContent = ''; });
        document.getElementById('editPwdInput').addEventListener('keydown', (e) => { if (e.key === 'Enter') document
                .getElementById('editPwdConfirm').click(); if (e.key === 'Escape') document.getElementById(
                    'editPwdCancel').click(); });
        document.getElementById('editPwdOverlay').addEventListener('click', (e) => { if (e.target === e.currentTarget)
                document.getElementById('editPwdCancel').click(); });

        // ============================================================
        // 10. НАБЛЮДАТЕЛЬ
        // ============================================================
        document.getElementById('observerToggleBtn').addEventListener('click', function() {
            if (!isAdmin) { showToast('Требуется авторизация', 'error'); return; }
            if (observerMode) {
                observerMode = false;
                this.textContent = '👁️ Наблюдатель';
                this.classList.remove('btn-primary');
                showToast('Режим наблюдателя выключен', 'warning');
                return;
            }
            document.getElementById('observerPwdOverlay').classList.add('show');
            document.getElementById('observerPwdInput').value = '';
            document.getElementById('observerPwdError').textContent = '';
            setTimeout(() => document.getElementById('observerPwdInput').focus(), 100);
        });

        document.getElementById('observerPwdConfirm').addEventListener('click', function() {
            if (document.getElementById('observerPwdInput').value === OBSERVER_PASSWORD) {
                document.getElementById('observerPwdOverlay').classList.remove('show');
                observerMode = true;
                const btn = document.getElementById('observerToggleBtn');
                btn.textContent = '👁️ Наблюдатель (ON)';
                btn.classList.add('btn-primary');
                showToast('Режим наблюдателя включён (только просмотр)', 'success');
                const panel = document.getElementById('dbHiddenPanel');
                const dbInterface = document.getElementById('dbInterface');
                panel.classList.add('active');
                dbInterface.classList.remove('hidden');
                renderTable();
            } else {
                document.getElementById('observerPwdError').textContent = '❌ Неверный пароль';
                document.getElementById('observerPwdInput').value = '';
                document.getElementById('observerPwdInput').focus();
            }
        });
        document.getElementById('observerPwdCancel').addEventListener('click', () => { document.getElementById(
                'observerPwdOverlay').classList.remove('show');
            document.getElementById('observerPwdError').textContent = ''; });
        document.getElementById('observerPwdInput').addEventListener('keydown', (e) => { if (e.key === 'Enter') document
                .getElementById('observerPwdConfirm').click(); if (e.key === 'Escape') document.getElementById(
                    'observerPwdCancel').click(); });
        document.getElementById('observerPwdOverlay').addEventListener('click', (e) => { if (e.target === e.currentTarget)
                document.getElementById('observerPwdCancel').click(); });

        // ============================================================
        // 11. КОРЗИНА
        // ============================================================
        function renderTrash() {
            const trash = JSON.parse(localStorage.getItem('vchk_trash')) || [];
            const c = document.getElementById('trashContent');
            c.innerHTML = '';
            if (trash.length === 0) { c.innerHTML =
                    `<div style="opacity:0.4; text-align:center; padding:12px;">Корзина пуста</div>`; return; }
            trash.forEach((item, idx) => {
                const div = document.createElement('div');
                div.className = 'trash-item';
                div.innerHTML =
                    `<span><strong>${item.fio || '—'}</strong> ${item.department ? '— ' + item.department : ''} <span style="opacity:0.4; font-size:0.6rem;">${item.deletedAt || ''}</span></span><button class="restore-btn" data-idx="${idx}">↩</button>`;
                c.appendChild(div);
                div.querySelector('.restore-btn').addEventListener('click', () => {
                    if (!isAdmin) { showToast('Требуется авторизация', 'error'); return; }
                    const restored = trash.splice(idx, 1)[0];
                    localStorage.setItem('vchk_trash', JSON.stringify(trash));
                    dbRecords.push(restored);
                    delete restored.deletedAt;
                    saveToStorage();
                    addLog('Восстановление', `${restored.fio}`);
                    renderTable();
                    renderTrash();
                    showToast(`Запись "${restored.fio}" восстановлена`, 'success');
                });
            });
        }

        document.getElementById('trashToggleBtn').addEventListener('click', function() {
            if (!isAdmin) { showToast('Требуется авторизация', 'error'); return; }
            document.getElementById('trashPanel').classList.toggle('active');
            renderTrash();
        });
        document.getElementById('clearTrashBtn').addEventListener('click', function() {
            if (!isAdmin) { showToast('Требуется авторизация', 'error'); return; }
            const trash = JSON.parse(localStorage.getItem('vchk_trash')) || [];
            if (trash.length === 0) return;
            if (confirm('Очистить корзину?')) { localStorage.setItem('vchk_trash', JSON.stringify([]));
                renderTrash();
                showToast('Корзина очищена', 'warning'); }
        });

        // ============================================================
        // 12. БАЗА ДАННЫХ
        // ============================================================
        function saveToStorage() {
            localStorage.setItem('vchk_db', JSON.stringify(dbRecords));
            updateStats();
            updateFilterOptions();
        }

        function generateId() { return Date.now().toString(36) + Math.random().toString(36).slice(2, 6); }

        function getFormData() {
            return {
                photo: document.getElementById('previewPhoto').src || '',
                fio: document.getElementById('fio').value.trim(),
                callsign: document.getElementById('callsign').value.trim(),
                birthDate: document.getElementById('birthDate').value,
                gender: document.getElementById('gender').value,
                citizenship: document.getElementById('citizenship').value.trim(),
                education: document.getElementById('education').value.trim(),
                family: document.getElementById('family').value.trim(),
                address: document.getElementById('address').value.trim(),
                department: document.getElementById('department').value.trim(),
                rank: document.getElementById('rank').value.trim(),
                chief: document.getElementById('chief').value.trim(),
                phone: document.getElementById('phone').value.trim(),
                social: document.getElementById('social').value.trim(),
                joinDate: document.getElementById('joinDate').value,
                notes: document.getElementById('notes').value.trim(),
                files: currentFiles.map(f => ({ name: f.name, size: f.size, type: f.type })),
                lastModified: new Date().toLocaleString()
            };
        }

        function fillForm(data) {
            document.getElementById('previewPhoto').src = data.photo || '';
            document.getElementById('fio').value = data.fio || '';
            document.getElementById('callsign').value = data.callsign || '';
            document.getElementById('birthDate').value = data.birthDate || '';
            document.getElementById('gender').value = data.gender || '';
            document.getElementById('citizenship').value = data.citizenship || '';
            document.getElementById('education').value = data.education || '';
            document.getElementById('family').value = data.family || '';
            document.getElementById('address').value = data.address || '';
            document.getElementById('department').value = data.department || '';
            document.getElementById('rank').value = data.rank || '';
            document.getElementById('chief').value = data.chief || '';
            document.getElementById('phone').value = data.phone || '';
            document.getElementById('social').value = data.social || '';
            document.getElementById('joinDate').value = data.joinDate || '';
            document.getElementById('notes').value = data.notes || '';
            currentFiles = data.files || [];
            renderFiles();
            formChanged = false;
            if (data.lastModified) {
                document.getElementById('selectedIdDisplay').textContent =
                    `Посл. изм: ${data.lastModified}`;
            }
        }

        function clearForm() {
            document.getElementById('previewPhoto').src = '';
            document.getElementById('fio').value = '';
            document.getElementById('callsign').value = '';
            document.getElementById('birthDate').value = '';
            document.getElementById('gender').value = '';
            document.getElementById('citizenship').value = '';
            document.getElementById('education').value = '';
            document.getElementById('family').value = '';
            document.getElementById('address').value = '';
            document.getElementById('department').value = '';
            document.getElementById('rank').value = '';
            document.getElementById('chief').value = '';
            document.getElementById('phone').value = '';
            document.getElementById('social').value = '';
            document.getElementById('joinDate').value = '';
            document.getElementById('notes').value = '';
            currentFiles = [];
            renderFiles();
            document.getElementById('photoInput').value = '';
            currentEditId = null;
            document.getElementById('selectedIdDisplay').textContent = 'Выбрано: нет';
            formChanged = false;
        }

        function renderFiles() {
            const list = document.getElementById('fileList');
            list.innerHTML = currentFiles.map((f, i) =>
                `<span class="file-tag">📎 ${f.name} <span class="remove-file" data-idx="${i}">✕</span></span>`
            ).join('');
            list.querySelectorAll('.remove-file').forEach(el => {
                el.addEventListener('click', () => { currentFiles.splice(parseInt(el.dataset.idx), 1);
                    renderFiles(); });
            });
        }

        document.getElementById('fileInput').addEventListener('change', function(e) {
            const files = e.target.files;
            for (let f of files) { currentFiles.push({ name: f.name, size: f.size, type: f.type, data: null }); }
            renderFiles();
            this.value = '';
            formChanged = true;
        });

        document.getElementById('photoInput').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = (ev) => { document.getElementById('previewPhoto').src = ev.target.result; };
            reader.readAsDataURL(file);
        });

        document.querySelectorAll('.db-card input, .db-card textarea, .db-card select').forEach(el => {
            el.addEventListener('input', () => { if (currentEditId) formChanged = true; });
        });

        window.addEventListener('beforeunload', (e) => {
            if (formChanged && currentEditId) { e.preventDefault();
                e.returnValue = ''; }
        });

        function getFilteredAndSorted() {
            let list = [...dbRecords];
            const q = document.getElementById('searchInput').value.toLowerCase().trim();
            const dept = document.getElementById('filterDept').value;
            if (q) {
                list = list.filter(r =>
                    (r.fio || '').toLowerCase().includes(q) ||
                    (r.callsign || '').toLowerCase().includes(q) ||
                    (r.department || '').toLowerCase().includes(q) ||
                    (r.rank || '').toLowerCase().includes(q) ||
                    (r.chief || '').toLowerCase().includes(q)
                );
            }
            if (dept) { list = list.filter(r => r.department === dept); }
            const field = currentSort.field;
            const asc = currentSort.asc;
            list.sort((a, b) => {
                let va = (a[field] || '').toString().toLowerCase();
                let vb = (b[field] || '').toString().toLowerCase();
                if (field === 'joinDate' || field === 'birthDate') { va = a[field] || '';
                    vb = b[field] || ''; }
                if (va < vb) return asc ? -1 : 1;
                if (va > vb) return asc ? 1 : -1;
                return 0;
            });
            return list;
        }

        function renderTable() {
            const list = getFilteredAndSorted();
            const tbody = document.getElementById('dbTableBody');
            tbody.innerHTML = '';
            if (list.length === 0) {
                tbody.innerHTML =
                    `<tr><td colspan="7" style="text-align:center; opacity:0.4; padding:20px;">Нет записей</td></tr>`;
                if (document.getElementById('selectAll')) document.getElementById('selectAll').checked = false;
                return;
            }
            list.forEach((rec) => {
                const tr = document.createElement('tr');
                const isAdminVisible = isAdmin ? '' : 'admin-only';
                tr.innerHTML = `
                    <td><input type="checkbox" class="row-checkbox ${isAdminVisible}" data-id="${rec.id}"></td>
                    <td><img src="${rec.photo || ''}" alt="фото" onerror="this.src=''"></td>
                    <td><strong>${rec.fio || '—'}</strong>${rec.callsign ? ` (${rec.callsign})` : ''}</td>
