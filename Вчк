        }
        body.dark .db-card h3 {
            color: #b0d0ff;
        }
        body.light .db-card h3 {
            color: #1a4a7a;
        }
        .field {
            margin-bottom: 8px;
            display: flex;
            flex-direction: column;
            gap: 2px;
        }
        .field label {
            font-size: 0.55rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 700;
            opacity: 0.6;
        }
        .field input,
        .field textarea,
        .field select {
