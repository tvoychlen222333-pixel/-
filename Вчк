            background: rgba(0, 6, 16, 0.15);
            border: 1px solid rgba(80, 160, 255, 0.03);
        }
        body.light .db-table-wrap {
            background: rgba(255, 255, 255, 0.2);
            border: 1px solid rgba(80, 160, 255, 0.06);
        }
        .db-table-wrap table {
            width: 100%;
